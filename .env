# ===== Main configuration (network & domains & storage) =====

STACK=tyr-lab
MASTER_FOLDER=/data/lab
MAIN_STACK_DOMAIN=asgard
NETWORK_INTERFACE=wlan0
NETWORK_MASK="192.168.1"
MAIN_STACK_IP_OCTET=130
BACKDROPS_SHARE_IP_OCTET=131
ADGUARD_IP_OCTET=222

# ===== This part can be configured, or can be left as is =====

BACKDROPS_SHARE_USER=admin
BACKDROPS_SHARE_PASSWORD=qwerty

# ===== Everything else is derived from the variables above =====

HOMEPAGE_VAR_DOMAIN="${MAIN_STACK_DOMAIN}.local"
LOCAL_SUBNET="${NETWORK_MASK}.0/24"
LOCAL_GATEWAY="${NETWORK_MASK}.1"
MAIN_STACK_IP="${NETWORK_MASK}.${MAIN_STACK_IP_OCTET}"
BACKDROPS_SHARE_IP="${NETWORK_MASK}.${BACKDROPS_SHARE_IP_OCTET}"
ADGUARD_IP="${NETWORK_MASK}.${ADGUARD_IP_OCTET}"
HOMEPAGE_HOSTNAME=localhost,${HOMEPAGE_VAR_DOMAIN},${MAIN_STACK_IP}

# Nested folder structure
# Make sure you persist/backup your CONFIGS folder, everything else is recoverable
CONFIGS_FOLDER=${MASTER_FOLDER}/configs
BACKDROPS_FOLDER=${MASTER_FOLDER}/backdrops
CACHE_FOLDER=${MASTER_FOLDER}/cache
COLD_FOLDER=${MASTER_FOLDER}/cold
HOT_FOLDER=${MASTER_FOLDER}/hot

# Optional variables
USER_ID=1000
GROUP_ID=${USER_ID}
#TIMEZONE=Etc/UTC # It's commented-out so that start.sh script will populate it.

# Ports opened in your host system
# Note that jellyfin also opens hardcoded: 8920, 7359, 1900
# (needed for discovery by apps)
# AdGuard exposes hardcoded 53 port, for DNS discovery
HOMEPAGE_PORT=80
GLANCES_PORT=61208
SONARR_PORT=8989
RADARR_PORT=7878
BAZARR_PORT=6767
PROWLARR_PORT=9696
QBITTORRENT_WEBUI_PORT=8080
QBITTORRENT_TORRENTING_PORT=33333
SEERR_PORT=5055
JELLYFIN_PORT=8096
JELLYSTAT_PORT=3000
KAPOWARR_PORT=5656
KAVITA_PORT=10888
ADGUARD_PORT=23002

# Homepage additional settings
HOMEPAGE_DISK_STATS_HOT=${HOT_FOLDER}
HOMEPAGE_DISK_STATS_COLD=${COLD_FOLDER}

# Homepage variables for referencing containers / servers.
HOMEPAGE_VAR_ADGUARD_ADDRESS=${ADGUARD_IP}
HOMEPAGE_VAR_CONTAINER_GATEWAY=${STACK}-gateway
HOMEPAGE_VAR_CONTAINER_DOCKERPROXY=${STACK}-dockerproxy
HOMEPAGE_VAR_CONTAINER_GLANCES=${STACK}-glances
HOMEPAGE_VAR_CONTAINER_SEERR=${STACK}-seerr
HOMEPAGE_VAR_CONTAINER_JELLYFIN=${STACK}-jellyfin
HOMEPAGE_VAR_CONTAINER_KAVITA=${STACK}-kavita
HOMEPAGE_VAR_CONTAINER_JELLYSTAT=${STACK}-jellystat
HOMEPAGE_VAR_CONTAINER_QBITTORRENT=${STACK}-qbittorrent
HOMEPAGE_VAR_CONTAINER_SONARR=${STACK}-sonarr
HOMEPAGE_VAR_CONTAINER_RADARR=${STACK}-radarr
HOMEPAGE_VAR_CONTAINER_BAZARR=${STACK}-bazarr
HOMEPAGE_VAR_CONTAINER_PROWLARR=${STACK}-prowlarr
HOMEPAGE_VAR_CONTAINER_KAPOWARR=${STACK}-kapowarr
HOMEPAGE_VAR_CONTAINER_ADGUARD=${STACK}-adguard
